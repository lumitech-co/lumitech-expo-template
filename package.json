{
  "name": "lumitech-expo-template",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typescript": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "android:uninstall": "cd android && ./gradlew uninstallAll",
    "android:clean": "cd android && ./gradlew clean && cd ../",
    "android:apk": "cd android && ./gradlew assembleRelease && cd ../",
    "android:bundle": "cd android && ./gradlew bundleRelease && cd ../",
    "prepare": "husky"
  },
  "dependencies": {
    "@gorhom/portal": "^1.0.14",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.16",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "expo": "^55.0.0",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "i18next": "^24.2.3",
    "immer": "^10.2.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^15.7.4",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^4.3.1",
    "react-native-modalfy": "^3.7.0",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-unistyles": "^2.2.0",
    "react-native-worklets": "0.7.4",
    "sonner-native": "^0.22.2",
    "ts-pattern": "^5.9.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.13"
